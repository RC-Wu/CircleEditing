        frontier_fallback_std_thr = _env_float("EDITSPLAT_FRONTIER_BLACKFACE_STD_THR", 0.02)
        frontier_fallback_min_coverage = _env_float("EDITSPLAT_FRONTIER_BLACKFACE_MIN_COVERAGE", 0.005)
