from pathlib import Path
from PIL import Image
import numpy as np
root=Path('runs/frontier_seed1_grid3_editstrong_211_epoch1_patchstability_tensorart_20260327_205251/debug_intermediates/initial_edit')
scores=[]
for d in sorted(root.iterdir()):
    if not d.is_dir():
        continue
    inp=np.asarray(Image.open(d/'input.png').convert('RGB'),dtype=np.float32)/255.0
    edt=np.asarray(Image.open(d/'initial_edit.png').convert('RGB').resize((inp.shape[1],inp.shape[0])) ,dtype=np.float32)/255.0
    score=float(np.abs(edt-inp).mean())
    view=int(d.name.split('_')[0].replace('view',''))
    scores.append((view,score))
print('scores',scores)
center=0.5*max(0,len(scores)-1)
anchor=max(scores,key=lambda t:(t[1],-abs(t[0]-center)))
print('anchor',anchor)
