from pathlib import Path
from PIL import Image, ImageDraw
base = Path('/dev_vepfs/rc_wu/edit/CircleEditing/runs/frontier_seed1_grid3_editstrong_211_epoch1_patchstability_tensorart_20260327_205251/train/ours_7010/renders')
new = Path('/dev_vepfs/rc_wu/edit/CircleEditing/runs/frontier_seed1_grid3_editstrong_211_epoch1_anchorhybrid_tensorart_20260327_211522/train/ours_7010/renders')
out = Path('/dev_vepfs/rc_wu/edit/CircleEditing/reports/ralph_loop_20260328/anchorhybrid_vs_tensorart_train_renders_20260327_211522.png')
idxs = [f'{i:05d}.png' for i in range(6)]
imgs = []
for name in idxs:
    imgs.append(('base_'+name[:-4], Image.open(base / name).convert('RGB')))
    imgs.append(('hybrid_'+name[:-4], Image.open(new / name).convert('RGB')))
W, H = imgs[0][1].size
label_h = 26
cols = 3
rows = (len(imgs) + cols - 1) // cols
sheet = Image.new('RGB', (cols * W, rows * (H + label_h)), 'white')
draw = ImageDraw.Draw(sheet)
for i, (label, im) in enumerate(imgs):
    x = (i % cols) * W
    y = (i // cols) * (H + label_h)
    sheet.paste(im, (x, y))
    draw.rectangle([x, y + H, x + W, y + H + label_h], fill='black')
    draw.text((x + 6, y + H + 6), label, fill='white')
sheet.save(out)
print(out)
