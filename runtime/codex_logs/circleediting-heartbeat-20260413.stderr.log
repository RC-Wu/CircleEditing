+    echo "  - dev01 gpu0 slot tail: $dev01_slot0"
+    echo "  - dev01 gpu1 slot tail: $dev01_slot1"
+    echo "  - dev02 status JSONs: $dev02_status; panel_final_grid count: $dev02_panels; $dev02_runner"
+    echo "- Exact PIDs or liveness:"
