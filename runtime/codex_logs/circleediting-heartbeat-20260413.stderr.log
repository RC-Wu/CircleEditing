block\n  vit_middle:\n    dim: 512                  # must match encoder's last channel\n    num_layers: 8\n    num_heads: 8\n    mlp_ratio: 4.0\n    dropout: 0.0\n\n  # Decoder: 16→32→64→128\n  decoder:\n    out_channels: 256\n    model_channels: [512, 256, 128, 64]\n    latent_channels: 32\n    num_blocks: [4, 6, 4, 2]\n    block_type: SparseConvNeXtBlock3d\n    up_block_type: SparseResBlockC2S3d\n    use_fp16: ${training.use_fp16}\n    use_checkpoint: false\n\n  # Parallel MLP head — bin classification\n  head:\n    hidden_dim: 256           # must match decoder.out_channels\n    mlp_hidden: 512\n    num_layers: 4\n    output_dim: 9             # 3 vertices × 3 axes\n    num_bins: 512             # 0 = regression, >0 = CE classification\n\ntraining:\n  max_epochs: 100\n  batch_size: 32\n  accumulate_grad_batches: 1\n  gradient_clip_val: 1.0\n  use_fp16: false             # TRELLIS2 internal fp16 for sparse conv (set true with 16-mixed)\n  precision: 32\n  devices: 2\n  strategy: ddp\n\n  optimizer:\n    name: AdamW\n    lr: 1.0e-4\n    weight_decay: 0.01\n    betas: [0.9, 0.95]\n\n  scheduler:\n    name: CosineAnnealingLR\n    T_max: ${training.max_epochs}\n    eta_min: 1.0e-6\n\n  # Loss weights\n  lambda_ce: 1.0              # CE reconstruction loss\n  lambda_l1: 1.0              # L1 reconstruction loss (unused in CE mode)\n  lambda_kl: 1.0e-5           # KL divergence\n  lambda_consistency: 0.1     # shared vertex consistency\n  offset_range: 0.5           # quantization range [-r, r] for bin encoding\n\n  val_check_interval: 0.25\n  log_every_n_steps: 50\n\ncheckpoint:\n  dirpath: /dev_vepfs/xiyu/armesh-dev/checkpoints/vae-poc-v2\n  every_n_epochs: 10\n\nwandb:\n  project: armesh-vae-poc\n  name: v2-vit-l1\n  tags: [vae, v2, vit-middle, l1, 128-grid]\n  offline: false\n\nseed: 42\n"}}
