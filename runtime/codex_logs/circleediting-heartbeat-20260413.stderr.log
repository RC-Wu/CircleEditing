ense256_v2_center_n_topk_8gpu_ft.yaml:43:  center_head_hidden: 128\\n./vae_poc/config/dense256_v2_center_n_topk_8gpu_ft.yaml:44:  center_head_layers: 2\\n./vae_poc/config/dense256_v2_center_n_topk_8gpu_ft.yaml:74:  dirpath: /dev_vepfs/xiyu/armesh-dev/checkpoints/vae-v2-center-n-topk-dense256\\n./vae_poc/config/dense256_v2_center_n_topk_8gpu_ft.yaml:82:  name: v2-center-n-topk-ft-8gpu\\n./vae_poc/config/dense256_v2_center_n_topk_8gpu_ft.yaml:83:  tags: [vae, v2, center_n_topk, 8gpu, finetune]\\n./tools/profile_variant_memory.py:35:    ap = argparse.ArgumentParser(description=\\\"Profile memory for original / center / center_n_topk variants.\\\")\\n./tools/profile_variant_memory.py:37:    ap.add_argument(\\\"--variant\\\", required=True, choices=[\\\"original\\\", \\\"center\\\", \\\"center_n_topk\\\"])\\n./tools/profile_variant_memory.py:64:    elif args.variant == \\\"center_n_topk\\\":\\n./tools/profile_variant_memory.py:148:    if module.model.center_head is not None:\\n./tools/profile_variant_memory.py:149:        outputs[\\\"center_logits\\\"] = module.model.center_head(head_hidden)\\n./scripts/run_controller_center_compare_2gpu.sh:206:  --config-name dense256_v2_center_n_topk_monitor_2gpu\\n./scripts/run_controller_center_n_topk_8gpu_swanlab.sh:6:RUN_NAME=\\\"center_n_topk_8gpu_swan…242144 tokens truncated…ter_grads(model_params, master_params):\\n    \\\"\\\"\\\"Copy fp16 model grads to fp32 master grad.\\\"\\\"\\\"\\n    master_params[0].grad = _flatten_dense_tensors(\\n        [p.grad.data.detach().float() for p in model_params]\\n    )\\n\\n\\ndef _master_params_to_model_params(model_params, master_params):\\n    \\\"\\\"\\\"Copy fp32 master to fp16 model weights.\\\"\\\"\\\"\\n    for p, mp in zip(model_params, _unflatten_dense_tensors(master_params[0].detach(), model_params)):\\n        p.detach().copy_(mp)\\n\\n\\ndef _wasserstein_1d_from_logits(\\n    logits_i: torch.Tensor,\\n    logits_j: torch.Tensor,\\n    bin_width: float,\\n) -> torch.Tensor:\\n    \\\"\\\"\\\"1D Wasserstein-1 distance over ordered bins.\\\"\\\"\\\"\\n    probs_i = F.softmax(logits_i.float(), dim=-1)\\n    probs_j = F.softmax(logits_j.float(), dim=-1)\\n    cdf_diff = torch.abs(probs_i.cumsum(dim=-1) - probs_j.cumsum(dim=-1)).sum(dim=-1)\\n    return (cdf_diff * bin_width).mean()\\n\\n\\nclass MeshFaceVAEModule(pl.LightningModule):\\n    def __init__(self, cfg: DictConfig):\\n        super().__init__()\\n        self.cfg = cfg\\n        self.save_hyperparameters(OmegaConf.to_container(cfg, resolve=True))\\n\\n        self.model = MeshFaceVAE(cfg)\\n\\n        self.manual_fp16 = cfg.training.get(\\\"use_fp16\\\", False)\\n        if self.manual_fp16:\\n            self.automatic_optimization = False\\n            self.log_loss_scale = 20.0\\n            self.fp16_scale_growth = 1e-3\\n\\n        self.lambda_ce = cfg.training.lambda_ce\\n        self.lambda_kl = cfg.training.lambda_kl\\n        self.lambda_consistency = cfg.training.lambda_consistency\\n        self.lambda_topo_edge = cfg.training.get(\\\"lambda_topo_edge\\\", 0.0)\\n        self.lambda_topo_boundary = cfg.training.get(\\\"lambda_topo_boundary\\\", 0.0)\\n        self.lambda_center = cfg.training.get(\\\"lambda_center\\\", 0.0)\\n        self.num_bins = cfg.data.num_bins\\n        self.offset_max = float(cfg.data.get(\\\"offset_max\\\", 1.0))\\n        self.consistency_max_pairs = cfg.training.get(\\\"consistency_max_pairs\\\", 10000)\\n        self.consistency_loss_type = str(cfg.training.get(\\\"consistency_loss_type\\\", \\\"w1\\\")).lower()\\n        self.debug_print_first_n_steps = int(cfg.training.get(\\\"debug_print_first_n_steps\\\", 2))\\n        self.debug_monitor_steps = int(cfg.training.get(\\\"debug_monitor_steps\\\", 0))\\n        self.debug_raise_on_none_batch = bool(cfg.training.get(\\\"debug_raise_on_none_batch\\\", False))\\n        self.debug_raise_on_empty_head = bool(cfg.training.get(\\\"debug_raise_on_empty_head\\\", False))\\n        self.debug_jsonl_dir = str(cfg.training.get(\\\"debug_jsonl_dir\\\", \\\"\\\"))\\n        self.debug_log_gradients = bool(cfg.training.get(\\\"debug_log_gradients\\\", False))\\n        self.center_objective = str(cfg.training.get(\\\"center_objective\\\", \\\"hard_ce\\\"))\\n        self.center_focal_gamma = float(cfg.training.get(\\\"center_focal_gamma\\\", 2.0))\\n        self.center_soft_temperature = float(cfg.training.get(\\\"center_soft_temperature\\\", 0.25))\\n        self.center_topm = int(cfg.training.get(\\\"center_topm\\\", 4))\\n        self._pending_grad_monitor: Optional[Dict[str, Any]] = None\\n\\n    def forward(self, batch, collect_debug: bool = False):\\n        return self.model(\\n            coords=batch[\\\"coords\\\"],\\n            feats=batch[\\\"feats\\\"],\\n            gt_bins=batch[\\\"bin_indices\\\"],\\n            head_mask=batch.get(\\\"head_mask\\\", None),\\n            collect_debug=collect_debug,\\n        )\\n\\n    def _compute_losses(self, batch, outputs) -> tuple[Dict[str, torch.Tensor], Dict[str, Any]]:\\n        losses = {}\\n        debug: Dict[str, Any] = {}\\n\\n        head_mask = batch.get(\\\"head_mask\\\", None)\\n        if head_mask is not None:\\n            gt_bins = batch[\\\"bin_indices\\\"][head_mask]\\n        else:\\n            gt_bins = batch[\\\"bin_indices\\\"]\\n        if self.debug_raise_on_empty_head and gt_bins.numel() == 0:\\n            raise RuntimeError(\\\"empty gt_bins after head_mask selection\\\")\\n\\n        debug[\\\"gt_bin_min\\\"] = float(gt_bins.min().item()) if gt_bins.numel() else -1.0\\n        debug[\\\"gt_bin_max\\\"] = float(gt_bins.max().item()) if gt_bins.numel() else -1.0\\n        debug[\\\"gt_bin_mean\\\"] = float(gt_bins.float().mean().item()) if gt_bins.numel() else 0.0\\n        debug[\\\"gt_bin_zero_frac\\\"] = float((gt_bins == 0).float().mean().item()) if gt_bins.numel() else 0.0\\n        debug[\\\"gt_bin_last_frac\\\"] = float((gt_bins == (self.num_bins - 1)).float().mean().item()) if gt_bins.numel() else 0.0\\n\\n        ce_v0 = F.cross_entropy(\\n            outputs[\\\"logits_v0\\\"].reshape(-1, self.num_bins),\\n            gt_bins[:, 0:3].reshape(-1),\\n        )\\n        ce_v1 = F.cross_entropy(\\n            outputs[\\\"logits_v1\\\"].reshape(-1, self.num_bins),\\n            gt_bins[:, 3:6].reshape(-1),\\n        )\\n        ce_v2 = F.cross_entropy(\\n            outputs[\\\"logits_v2\\\"].reshape(-1, self.num_bins),\\n            gt_bins[:, 6:9].reshape(-1),\\n        )\\n        losses[\\\"ce_recon\\\"] = (ce_v0 + ce_v1 + ce_v2) / 3.0\\n        losses[\\\"ce_v0\\\"] = ce_v0\\n        losses[\\\"ce_v1\\\"] = ce_v1\\n        losses[\\\"ce_v2\\\"] = ce_v2\\n        debug[\\\"ce_v0\\\"] = float(ce_v0.detach().item())\\n        debug[\\\"ce_v1\\\"] = float(ce_v1.detach().item())\\n        debug[\\\"ce_v2\\\"] = float(ce_v2.detach().item())\\n\\n        mean = outputs[\\\"mean\\\"]\\n        logvar = outputs[\\\"logvar\\\"]\\n        losses[\\\"kl\\\"] = -0.5 * torch.mean(1 + logvar - mean.pow(2) - logvar.exp())\\n\\n        if self.lambda_consistency > 0 and \\\"consistency_head_i\\\" in batch and batch[\\\"consistency_head_i\\\"].numel() > 0:\\n            vertex_logits = torch.stack(\\n                [outputs[\\\"logits_v0\\\"], outputs[\\\"logits_v1\\\"], outputs[\\\"logits_v2\\\"]],\\n                dim=1,\\n            )  # [K, 3_verts, 3_axes, num_bins]\\n            max_pairs = min(int(batch[\\\"consistency_head_i\\\"].numel()), int(self.consistency_max_pairs))\\n            hi = batch[\\\"consistency_head_i\\\"][:max_pairs].to(self.device)\\n            hj = batch[\\\"consistency_head_j\\\"][:max_pairs].to(self.device)\\n            vi = batch[\\\"consistency_vert_i\\\"][:max_pairs].to(self.device)\\n            vj = batch[\\\"consistency_vert_j\\\"][:max_pairs].to(self.device)\\n            logits_i = vertex_logits[hi, vi]\\n            logits_j = vertex_logits[hj, vj]\\n            bin_width = (2.0 * self.offset_max) / float(self.num_bins)\\n\\n            if self.consistency_loss_type in (\\\"w1\\\", \\\"wasserstein\\\", \\\"wasserstein1\\\", \\\"emd\\\"):\\n                losses[\\\"consistency\\\"] = _wasserstein_1d_from_logits(logits_i, logits_j, bin_width)\\n            elif self.consistency_loss_type in (\\\"mse\\\", \\\"mean_mse\\\", \\\"soft_mse\\\"):\\n                bin_range = torch.arange(self.num_bins, device=logits_i.device, dtype=torch.float32)\\n                soft_i = (F.softmax(logits_i.float(), dim=-1) * bin_range).sum(dim=-1)\\n                soft_j = (F.softmax(logits_j.float(), dim=-1) * bin_range).sum(dim=-1)\\n                losses[\\\"consistency\\\"] = F.mse_loss(soft_i * bin_width, soft_j * bin_width)\\n            else:\\n                raise ValueError(f\\\"Unsupported consistency_loss_type: {self.consistency_loss_type}\\\")\\n        else:\\n            losses[\\\"consistency\\\"] = torch.tensor(0.0, device=self.device)\\n\\n        if \\\"topo_edge_logits\\\" in outputs and self.lambda_topo_edge > 0:\\n            topo_flags = batch[\\\"topo_flags\\\"].to(self.device)\\n            if head_mask is not None:\\n                topo_flags = topo_flags[head_mask]\\n            edge_targets = topo_flags[:, 0].float()\\n            logits = outputs[\\\"topo_edge_logits\\\"]\\n            losses[\\\"topo_edge\\\"] = F.binary_cross_entropy_with_logits(logits, edge_targets)\\n            with torch.no_grad():\\n                preds = (logits > 0).float()\\n                losses[\\\"topo_edge_acc\\\"] = (preds == edge_targets).float().mean()\\n        else:\\n            losses[\\\"topo_edge\\\"] = torch.tensor(0.0, device=self.device)\\n\\n        if \\\"topo_boundary_logits\\\" in outputs and self.lambda_topo_boundary > 0:\\n            topo_flags_all = batch[\\\"topo_flags\\\"].to(self.device)\\n            if head_mask is not None:\\n                topo_flags_all = topo_flags_all[head_mask]\\n            boundary_targets = topo_flags_all[:, 1].float()\\n            logits = outputs[\\\"topo_boundary_logits\\\"]\\n            losses[\\\"topo_boundary\\\"] = F.binary_cross_entropy_with_logits(logits, boundary_targets)\\n            with torch.no_grad():\\n                preds = (logits > 0).float()\\n                losses[\\\"topo_boundary_acc\\\"] = (preds == boundary_targets).float().mean()\\n        else:\\n            losses[\\\"topo_boundary\\\"] = torch.tensor(0.0, device=self.device)\\n\\n        center_loss, center_acc, center_debug = self._compute_center_objective(batch, outputs, head_mask=head_mask)\\n        losses[\\\"center\\\"] = center_loss\\n        losses[\\\"center_acc_hard\\\"] = center_acc\\n        losses[\\\"center_target_mass\\\"] = torch.tensor(\\n            float(center_debug.get(\\\"target_mass\\\", 0.0)),\\n            device=self.device,\\n        )\\n        losses[\\\"center_target_hit\\\"] = torch.tensor(\\n            float(center_debug.get(\\\"target_hit\\\", center_debug.get(\\\"acc\\\", 0.0))),\\n            device=self.device,\\n        )\\n        losses[\\\"center_target_entropy\\\"] = torch.tensor(\\n            float(center_debug.get(\\\"target_entropy\\\", 0.0)),\\n            device=self.device,\\n        )\\n        losses[\\\"center_support_size\\\"] = torch.tensor(\\n            float(center_debug.get(\\\"support_size\\\", 0.0)),\\n            device=self.device,\\n        )\\n        debug.update({f\\\"center_{k}\\\": v for k, v in center_debug.items()})\\n\\n        losses[\\\"total\\\"] = (\\n            self.lambda_ce * losses[\\\"ce_recon\\\"]\\n            + self.lambda_kl * losses[\\\"kl\\\"]\\n            + self.lambda_consistency * losses[\\\"consistency\\\"]\\n            + self.lambda_topo_edge * losses[\\\"topo_edge\\\"]\\n            + self.lambda_topo_boundary * losses[\\\"topo_boundary\\\"]\\n            + self.lambda_center * losses[\\\"center\\\"]\\n        )\\n\\n        with torch.no_grad():\\n            pred_bins = torch.cat(\\n                [\\n                    outputs[\\\"logits_v0\\\"].argmax(dim=-1),\\n                    outputs[\\\"logits_v1\\\"].argmax(dim=-1),\\n                    outputs[\\\"logits_v2\\\"].argmax(dim=-1),\\n                ],\\n                dim=-1,\\n            )\\n            losses[\\\"acc\\\"] = (pred_bins == gt_bins).float().mean()\\n            losses[\\\"mae_bins\\\"] = (pred_bins.float() - gt_bins.float()).abs().mean()\\n            losses[\\\"acc_v0\\\"] = (pred_bins[:, 0:3] == gt_bins[:, 0:3]).all(dim=-1).float().mean()\\n            losses[\\\"acc_v1\\\"] = (pred_bins[:, 3:6] == gt_bins[:, 3:6]).all(dim=-1).float().mean()\\n            losses[\\\"acc_v2\\\"] = (pred_bins[:, 6:9] == gt_bins[:, 6:9]).all(dim=-1).float().mean()\\n            losses[\\\"acc_face\\\"] = (pred_bins == gt_bins).reshape(-1, 9).all(dim=-1).float().mean()\\n            debug[\\\"pred_bin_mean\\\"] = float(pred_bins.float().mean().item()) if pred_bins.numel() else 0.0\\n            debug[\\\"pred_bin_zero_frac\\\"] = float((pred_bins == 0).float().mean().item()) if pred_bins.numel() else 0.0\\n            debug[\\\"pred_bin_last_frac\\\"] = float((pred_bins == (self.num_bins - 1)).float().mean().item()) if pred_bins.numel() else 0.0\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/dev_vepfs/rc_wu/codex_subagents/20260328_mesh_center_wave2/headmask-migration/stdout.log:28:{\"type\":\"item.started\",\"item\":{\"id\":\"item_15\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,220p' vae_poc/config/dense256_v2_center_n_topk.yaml\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n/dev_vepfs/rc_wu/codex_subagents/20260328_mesh_center_wave2/headmask-migration/stdout.log:30:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_14\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '680,770p' vae_poc/trainer.py\\\"\",\"aggregated_output\":\"\\n    def validation_step(self, batch, batch_idx):\\n        if batch is None:\\n            payload = {\\n                \\\"stage\\\": \\\"val\\\",\\n                \\\"rank\\\": int(os.environ.get(\\\"LOCAL_RANK\\\", \\\"0\\\") or 0),\\n                \\\"global_step\\\": int(self.global_step),\\n                \\\"batch_idx\\\": int(batch_idx),\\n                \\\"event\\\": \\\"none_batch\\\",\\n            }\\n            print(\\\"[monitor-json]\\\" + json.dumps(payload, ensure_ascii=False))\\n            self._append_debug_jsonl(payload, stage=\\\"val\\\")\\n            if self.debug_raise_on_none_batch:\\n                raise RuntimeError(\\\"validation_step received None batch\\\")\\n            return None\\n\\n        self._debug_batch_summary(\\\"val\\\", batch, batch_idx)\\n\\n        collect_debug = self._should_monitor_step(batch_idx)\\n        outputs = self(batch, collect_debug=collect_debug)\\n        losses, debug = self._compute_losses(batch, outputs)\\n\\n        for k, v in losses.items():\\n            self.log(f\\\"val/{k}\\\", v, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n\\n        head_mask = batch.get(\\\"head_mask\\\", None)\\n        outputs_ar = self.model(\\n            coords=batch[\\\"coords\\\"],\\n            feats=batch[\\\"feats\\\"],\\n            gt_bins=None,\\n            head_mask=head_mask,\\n        )\\n\\n        if head_mask is not None:\\n            gt_bins_ar = batch[\\\"bin_indices\\\"][head_mask]\\n        else:\\n            gt_bins_ar = batch[\\\"bin_indices\\\"]\\n\\n        with torch.no_grad():\\n            pred_ar = torch.cat(\\n                [\\n                    outputs_ar[\\\"logits_v0\\\"].argmax(dim=-1),\\n                    outputs_ar[\\\"logits_v1\\\"].argmax(dim=-1),\\n                    outputs_ar[\\\"logits_v2\\\"].argmax(dim=-1),\\n                ],\\n                dim=-1,\\n            )\\n            ar_acc = (pred_ar == gt_bins_ar).float().mean()\\n            ar_acc_face = (pred_ar == gt_bins_ar).reshape(-1, 9).all(dim=-1).float().mean()\\n            ar_acc_v0 = (pred_ar[:, 0:3] == gt_bins_ar[:, 0:3]).all(dim=-1).float().mean()\\n            ar_acc_v1 = (pred_ar[:, 3:6] == gt_bins_ar[:, 3:6]).all(dim=-1).float().mean()\\n            ar_acc_v2 = (pred_ar[:, 6:9] == gt_bins_ar[:, 6:9]).all(dim=-1).float().mean()\\n\\n        self.log(\\\"val/ar_acc\\\", ar_acc, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n        self.log(\\\"val/ar_acc_face\\\", ar_acc_face, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n        self.log(\\\"val/ar_acc_v0\\\", ar_acc_v0, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n        self.log(\\\"val/ar_acc_v1\\\", ar_acc_v1, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n        self.log(\\\"val/ar_acc_v2\\\", ar_acc_v2, on_step=False, on_epoch=True, sync_dist=True, batch_size=batch[\\\"batch_size\\\"])\\n\\n        if \\\"center_logits\\\" in outputs_ar and \\\"center_mask\\\" in batch:\\n            _, ar_center_acc, ar_center_debug = self._compute_center_objective(batch, outputs_ar, head_mask=head_mask)\\n            self.log(\\n                \\\"val/ar_center_acc_hard\\\",\\n                ar_center_acc,\\n                on_step=False,\\n                on_epoch=True,\\n                sync_dist=True,\\n                batch_size=batch[\\\"batch_size\\\"],\\n            )\\n            for debug_key, metric_name in (\\n                (\\\"target_mass\\\", \\\"val/ar_center_target_mass\\\"),\\n                (\\\"target_hit\\\", \\\"val/ar_center_target_hit\\\"),\\n                (\\\"target_entropy\\\", \\\"val/ar_center_target_entropy\\\"),\\n                (\\\"support_size\\\", \\\"val/ar_center_support_size\\\"),\\n            ):\\n                self.log(\\n                    metric_name,\\n                    float(ar_center_debug.get(debug_key, 0.0)),\\n                    on_step=False,\\n                    on_epoch=True,\\n                    sync_dist=True,\\n                    batch_size=batch[\\\"batch_size\\\"],\\n                )\\n\\n        if collect_debug:\\n            self._emit_step_monitor(\\n                stage=\\\"val\\\",\\n                batch_idx=batch_idx,\\n                batch=batch,\\n                outputs=outputs,\\n                losses=losses,\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/dev_vepfs/rc_wu/codex_subagents/20260328_mesh_center_wave2/headmask-migration/stdout.log:31:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_15\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,220p' vae_poc/config/dense256_v2_center_n_topk.yaml\\\"\",\"aggregated_output\":\"data:\\n  csv_path: /dev_vepfs/xiyu/armesh-dev/data/16k-face-27b-pass.csv\\n  drc_dir: /dev_vepfs/xiyu/armesh-dev/data/draco\\n  grid_resolution: 256\\n  num_bins: 256\\n  max_faces: 16000\\n  val_fraction: 0.05\\n  num_workers: 0\\n  pin_memory: true\\n  augment_vertex_perm: true\\n  edge_band_radius: 1.5\\n  interior_log_base: 8.0\\n  interior_log_scale: 16.0\\n  interior_cap: 50\\n  max_head_tokens: 200000\\n\\nmodel:\\n  encoder:\\n    in_channels: 11\\n    model_channels: [64, 128, 256, 512]\\n    latent_channels: 32\\n    num_blocks: [2, 4, 8, 4]\\n    block_type: SparseConvNeXtBlock3d\\n    down_block_type: SparseResBlockS2C3d\\n    use_fp16: false\\n    use_checkpoint: false\\n  decoder:\\n    out_channels: 256\\n    model_channels: [512, 256, 128, 64]\\n    latent_channels: 32\\n    num_blocks: [4, 8, 4, 2]\\n    block_type: SparseConvNeXtBlock3d\\n    up_block_type: SparseResBlockC2S3d\\n    use_fp16: false\\n    use_checkpoint: false\\n  head:\\n    hidden_dim: 256\\n    num_bins: ${data.num_bins}\\n    mlp_hidden: 512\\n    num_layers: 3\\n  topo_head_hidden: 128\\n  topo_head_layers: 2\\n  center_head_hidden: 128\\n  center_head_layers: 2\\n\\ntraining:\\n  max_epochs: 1\\n  batch_size: 1\\n  accumulate_grad_batches: 1\\n  gradient_clip_val: 1.0\\n  use_fp16: false\\n  precision: 32\\n  devices: 1\\n  strategy: auto\\n  limit_train_batches: 1\\n  limit_val_batches: 1\\n  optimizer:\\n    name: AdamW\\n    lr: 1.0e-4\\n    weight_decay: 0.01\\n    betas: [0.9, 0.95]\\n  scheduler:\\n    name: CosineAnnealingLR\\n    T_max: 1\\n    eta_min: 0.0\\n  lambda_ce: 1.0\\n  lambda_kl: 0.0\\n  lambda_consistency: 0.0\\n  lambda_topo_edge: 0.0\\n  lambda_topo_boundary: 0.0\\n  lambda_center: 0.1\\n  val_check_interval: 1.0\\n  log_every_n_steps: 1\\n\\ncheckpoint:\\n  dirpath: /dev_vepfs/rc_wu/_codex_staging/armesh-dev-codex-20260324/runs/profile_checkpoints/center_n_topk\\n  save_top_k: -1\\n  monitor: val/total\\n  mode: min\\n  every_n_epochs: 1\\n\\nwandb:\\n  project: armesh-vae-v2\\n  name: v2-center-n-topk-profile\\n  tags: [vae, v2, center_n_topk, profile, 1gpu]\\n  offline: true\\n\\nseed: 42\\ninit_from_ckpt: /dev_vepfs/xiyu/armesh-dev/checkpoints/vae-v2-dense256/vae-poc-epochepoch=29-val/total=0.5929.ckpt\\n\\r\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/dev_vepfs/rc_wu/codex_subagents/20260328_mesh_center_wave2/headmask-migration/stdout.log:32:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_16\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '240,360p' vae_poc/trainer.py\\\"\",\"aggregated_output\":\"            debug[\\\"pred_bin_last_frac\\\"] = float((pred_bins == (self.num_bins - 1)).float().mean().item()) if pred_bins.numel() else 0.0\\n\\n        if \\\"debug\\\" in outputs:\\n            debug[\\\"model_debug\\\"] = outputs[\\\"debug\\\"]\\n\\n        return losses, debug\\n\\n    def _compute_center_objective(self, batch, outputs, head_mask: Optional[torch.Tensor]):\\n        if self.lambda_center <= 0 or \\\"center_logits\\\" not in outputs or \\\"center_mask\\\" not in batch:\\n            zero = torch.tensor(0.0, device=self.device)\\n            return zero, zero, {\\n                \\\"enabled\\\": 0.0,\\n                \\\"head_tokens\\\": 0.0,\\n                \\\"center_tokens\\\": 0.0,\\n                \\\"valid_faces\\\": 0.0,\\n                \\\"target_mass\\\": 0.0,\\n                \\\"target_entropy\\\": 0.0,\\n                \\\"support_size\\\": 0.0,\\n                \\\"target_hit\\\": 0.0,\\n            }\\n\\n        center_logits = outputs[\\\"center_logits\\\"].float()\\n        face_ids = batch[\\\"face_ids\\\"].to(self.device)\\n        center_mask = batch[\\\"center_mask\\\"].to(self.device)\\n        dist_to_centroid = batch[\\\"dist_to_centroid\\\"].to(self.device)\\n\\n        if head_mask is not None:\\n            face_ids = face_ids[head_mask]\\n            center_mask = center_mask[head_mask]\\n            dist_to_centroid = dist_to_centroid[head_mask]\\n\\n        if center_logits.numel() == 0 or center_mask.sum() == 0:\\n            zero = torch.tensor(0.0, device=self.device)\\n            return zero, zero, {\\n                \\\"enabled\\\": 1.0,\\n                \\\"objective\\\": self.center_objective,\\n                \\\"head_tokens\\\": float(center_logits.numel()),\\n                \\\"center_tokens\\\": float(center_mask.sum().item()),\\n                \\\"valid_faces\\\": 0.0,\\n                \\\"logit_mean\\\": float(center_logits.mean().item()) if center_logits.numel() else 0.0,\\n                \\\"logit_std\\\": float(center_logits.std(unbiased=False).item()) if center_logits.numel() else 0.0,\\n                \\\"logit_absmax\\\": float(center_logits.abs().max().item()) if center_logits.numel() else 0.0,\\n                \\\"target_mass\\\": 0.0,\\n                \\\"target_entropy\\\": 0.0,\\n                \\\"support_size\\\": 0.0,\\n                \\\"target_hit\\\": 0.0,\\n            }\\n\\n        total_faces = int(batch.get(\\\"total_faces\\\", int(face_ids.max().item()) + 1))\\n        neg_inf = torch.full((total_faces,), float(\\\"-inf\\\"), device=self.device)\\n        max_per_face = neg_inf.clone()\\n        max_per_face.scatter_reduce_(0, face_ids, center_logits, reduce=\\\"amax\\\", include_self=True)\\n\\n        shifted = torch.exp(center_logits - max_per_face[face_ids])\\n        sumexp_per_face = torch.zeros((total_faces,), device=self.device)\\n        sumexp_per_face.scatter_add_(0, face_ids, shifted)\\n\\n        target_logits = neg_inf.clone()\\n        target_face_ids = face_ids[center_mask]\\n        target_logits.scatter_(0, target_face_ids, center_logits[center_mask])\\n\\n        valid = torch.isfinite(target_logits)\\n        if not valid.any():\\n            zero = torch.tensor(0.0, device=self.device)\\n            return zero, zero, {\\n                \\\"enabled\\\": 1.0,\\n                \\\"objective\\\": self.center_objective,\\n                \\\"head_tokens\\\": float(center_logits.numel()),\\n                \\\"center_tokens\\\": float(center_mask.sum().item()),\\n                \\\"valid_faces\\\": 0.0,\\n                \\\"logit_mean\\\": float(center_logits.mean().item()),\\n                \\\"logit_std\\\": float(center_logits.std(unbiased=False).item()) if center_logits.numel() > 1 else 0.0,\\n                \\\"logit_absmax\\\": float(center_logits.abs().max().item()),\\n                \\\"target_mass\\\": 0.0,\\n                \\\"target_entropy\\\": 0.0,\\n                \\\"support_size\\\": 0.0,\\n                \\\"target_hit\\\": 0.0,\\n            }\\n\\n        face_ce = torch.log(sumexp_per_face[valid]) + max_per_face[valid] - target_logits[valid]\\n        face_target_mass = torch.exp(-face_ce).clamp(0.0, 1.0)\\n        target_mass = face_target_mass.mean()\\n        target_entropy = torch.tensor(0.0, device=self.device)\\n        support_size = torch.tensor(1.0, device=self.device)\\n        target_hit = torch.tensor(0.0, device=self.device)\\n\\n        if self.center_objective == \\\"hard_ce\\\":\\n            center_loss = face_ce.mean()\\n        elif self.center_objective == \\\"focal_ce\\\":\\n            pt = torch.exp(-(face_ce.detach()))\\n            focal_weight = (1.0 - pt).clamp_min(0.0).pow(self.center_focal_gamma)\\n            center_loss = (focal_weight * face_ce).mean()\\n        elif self.center_objective in {\\\"soft_distance\\\", \\\"topm_uniform\\\"}:\\n            unique_faces = face_ids.unique(sorted=True)\\n            per_face_losses = []\\n            per_face_target_mass = []\\n            per_face_target_entropy = []\\n            per_face_support = []\\n            per_face_target_hit = []\\n            for face_id in unique_faces.tolist():\\n                mask = face_ids == face_id\\n                logits_face = center_logits[mask]\\n                dist_face = dist_to_centroid[mask]\\n                if logits_face.numel() == 0:\\n                    continue\\n                log_probs = F.log_softmax(logits_face, dim=0)\\n                probs_face = log_probs.exp()\\n                if self.center_objective == \\\"soft_distance\\\":\\n                    rel = dist_face - dist_face.min()\\n                    rel = rel / rel.max().clamp_min(1e-8)\\n                    target = torch.softmax(-rel / max(self.center_soft_temperature, 1e-6), dim=0)\\n                    per_face_target_hit.append((probs_face.argmax() == target.argmax()).float())\\n                else:\\n                    topm = min(self.center_topm, int(logits_face.numel()))\\n                    target = torch.zeros_like(logits_face)\\n                    top_idx = torch.argsort(dist_face)[:topm]\\n                    target[top_idx] = 1.0 / float(topm)\\n                    per_face_target_hit.append((target[probs_face.argmax()] > 0).float())\\n                per_face_losses.append(-(target * log_probs).sum())\\n                per_face_target_mass.append((target * probs_face).sum())\\n                per_face_target_entropy.append(-(target * target.clamp_min(1e-12).log()).sum())\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/dev_vepfs/rc_wu/codex_subagents/202