+from __future__ import annotations
+
+import importlib.util
+import json
+import shutil
+import sys
+import textwrap
+import tempfile
+import unittest
+from pathlib import Path
+
+
+SCRIPT_PATH = (
+    Path(__file__).resolve().parent.parent
+    / "scripts"
+    / "build_fixed_gpu_overnight_queue.py"
+)
+
+
+def load_queue_builder():
+    spec = importlib.util.spec_from_file_location("queue_builder_under_test", SCRIPT_PATH)
+    if spec is None or spec.loader is None:
+        raise RuntimeError(f"Unable to load queue builder module from {SCRIPT_PATH}")
+    module = importlib.util.module_from_spec(spec)
+    sys.modules[spec.name] = module
+    spec.loader.exec_module(module)
+    return module
+
+
+def write_launcher(path: Path, *, supports_wave19_fields: bool) -> None:
+    experiment_fields = [
+        "    name: str",
+        "    gpu: int",
+        '    case_name: str = "face"',
+    ]
+    if supports_wave19_fields:
+        experiment_fields.extend(
+            [
+                "    resolution: int = 384",
+                "    epoch: int = 2",
+            ]
+        )
+    path.write_text(
+        "\n".join(
+            [
+                "from dataclasses import dataclass",
+                "",
+                "",
+                "@dataclass",
+                "class Experiment:",
+                *experiment_fields,
+                "",
+                "",
+                "def build_run_name(exp: Experiment, wave_name: str) -> str:",
+                '    suffix = ""',
+                '    if hasattr(exp, "resolution"):',
+                '        suffix = f"_r{exp.resolution}"',
+                '    return f"{wave_name}_{exp.case_name}_{exp.name}{suffix}"',
+                "",
+            ]
+        ),
+        encoding="utf-8",
+    )
+
+
+class BuildFixedGpuOvernightQueueTests(unittest.TestCase):
+    def test_gc_job_recovers_launcher_from_existing_slot_script(self) -> None:
+        tmp_path = Path(tempfile.mkdtemp(prefix="queue_builder_test_"))
+        self.addCleanup(lambda: shutil.rmtree(tmp_path, ignore_errors=True))
+
+        queue_builder = load_queue_builder()
+        queue_builder.DEFAULT_LAUNCHER_MODULE = tmp_path / "default_launcher.py"
+        write_launcher(queue_builder.DEFAULT_LAUNCHER_MODULE, supports_wave19_fields=False)
+
+        wave_launcher = tmp_path / "wave19_launcher.py"
+        write_launcher(wave_launcher, supports_wave19_fields=True)
+
+        queue_root = tmp_path / "queues"
+        wave_name = "wave19"
+        queue_wave_root = queue_root / wave_name
+        (queue_wave_root / "scripts").mkdir(parents=True)
+        (queue_wave_root / "scripts" / "slot_gpu0.sh").write_text(
+            (
+                "python3 build_fixed_gpu_overnight_queue.py run-one "
+                f"--launcher-module {wave_launcher} "
+                "--queue-root /tmp/queues --wave-name wave19 --slot-gpu 0 --job-json /tmp/job.json\n"
+            ),
+            encoding="utf-8",
+        )
+
+        job_json = queue_wave_root / "job.json"
+        job_json.write_text(
+            json.dumps(
+                {
+                    "name": "carrier_probe",
+                    "exp_kwargs": {
+                        "case_name": "face",
+                        "resolution": 384,
+                        "epoch": 2,
+                    },
+                    "extra_env": {},
+                }
+            ),
+            encoding="utf-8",
+        )
+
+        run_root = queue_wave_root / "results" / "wave19_face_carrier_probe_r384"
+        checkpoint = run_root / "point_cloud" / "iteration_7" / "chkpnt7000.pth"
+        checkpoint.parent.mkdir(parents=True)
+        checkpoint.write_text("stub", encoding="utf-8")
+
+        queue_builder.gc_job(queue_root=queue_root, wave_name=wave_name, job_json=job_json)
+
+        self.assertFalse(checkpoint.exists())
+
+    def test_render_slot_script_passes_launcher_to_gc_job(self) -> None:
+        queue_builder = load_queue_builder()
+        slot = queue_builder.QueueSlot(gpu=1)
+        jobs = [queue_builder.QueueJob(name="carrier_probe")]
+        launcher_module_path = Path("/tmp/launch_carrier_probe_wave.py")
+        script_text = queue_builder.render_slot_script(
+            slot=slot,
+            jobs=jobs,
+            launcher_module_path=launcher_module_path,
+            queue_root=Path("/tmp/queues"),
+            wave_name="wave19",
+            queue_script_path=Path("/tmp/build_fixed_gpu_overnight_queue.py"),
+        )
+
+        self.assertIn("gc-job", script_text)
+        self.assertIn(f"--launcher-module {launcher_module_path}", script_text)
+
+
+if __name__ == "__main__":
+    unittest.main()

