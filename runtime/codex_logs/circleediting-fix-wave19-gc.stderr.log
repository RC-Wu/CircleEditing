        f"render_items={['RGB', 'Depth', 'Edge', 'Normal', 'Curvature', 'Feature Map']!r}, "
        f"view_shuffling=False"
        ")\n"
    )
    cfg_path.write_text(cfg_text, encoding="utf-8")
    return cfg_path


