+def resolve_queue_launcher_module_path(
+    queue_wave_root: Path,
+    launcher_module_path: Path | None = None,
+) -> Path:
+    if launcher_module_path is not None:
+        return launcher_module_path
+
+    queue_config_path = queue_wave_root / QUEUE_CONFIG_FILENAME
+    if queue_config_path.exists():
+        try:
+            payload = json.loads(queue_config_path.read_text(encoding="utf-8"))
+        except Exception:
+            payload = {}
+        if isinstance(payload, dict):
+            configured_path = payload.get("launcher_module")
+            if configured_path:
+                return Path(configured_path)
+
+    scripts_dir = queue_wave_root / "scripts"
+    for script_path in sorted(scripts_dir.glob("slot_*.sh")):
+        try:
+            lines = script_path.read_text(encoding="utf-8").splitlines()
+        except OSError:
+            continue
+        for line in lines:
+            if "--launcher-module" not in line:
+                continue
+            try:
+                tokens = shlex.split(line)
+            except ValueError:
+                continue
+            for idx, token in enumerate(tokens):
+                if token == "--launcher-module" and idx + 1 < len(tokens):
+                    return Path(tokens[idx + 1])
+
+    return DEFAULT_LAUNCHER_MODULE
+
